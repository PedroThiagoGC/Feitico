# Frontend public vars used by Vite.
VITE_SUPABASE_PROJECT_ID=xvyyxymzixptvoizrcpk
VITE_SUPABASE_URL=https://xvyyxymzixptvoizrcpk.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Server-side vars. Configure these in Vercel, but do not expose them with the VITE_ prefix.
