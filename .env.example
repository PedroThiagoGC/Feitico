# Frontend public vars used by Vite.
VITE_SUPABASE_PROJECT_ID=yrnrjbrzlzyvnyccsmcc
VITE_SUPABASE_URL=https://yrnrjbrzlzyvnyccsmcc.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
VITE_AUTH_STORAGE_KEY=feitico.auth.session
VITE_AUTH_SESSION_MAX_DAYS=15
VITE_AUTH_INACTIVITY_HOURS=24
VITE_ADMIN_ALLOWED_EMAILS=admin@exemplo.com

# Server-side vars. Configure these in Vercel, but do not expose them with the VITE_ prefix.
SUPABASE_URL=https://yrnrjbrzlzyvnyccsmcc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Use URL-encoded passwords in connection strings when the password contains special characters.
DATABASE_URL="postgresql://postgres.yrnrjbrzlzyvnyccsmcc:[URL-ENCODED-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.yrnrjbrzlzyvnyccsmcc:[URL-ENCODED-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Optional split database vars for platforms or scripts that do not use DATABASE_URL directly.
DATABASE_HOST=aws-1-sa-east-1.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_USERNAME=postgres.yrnrjbrzlzyvnyccsmcc
DATABASE_PASSWORD="your-db-password"
DATABASE_NAME=postgres
DATABASE_SSLMODE=require
