SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Use URL-encoded passwords in connection strings when the password contains special characters.
DATABASE_URL="postgresql://postgres.xvyyxymzixptvoizrcpk:[URL-ENCODED-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xvyyxymzixptvoizrcpk:[URL-ENCODED-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Optional split database vars for platforms or scripts that do not use DATABASE_URL directly.
