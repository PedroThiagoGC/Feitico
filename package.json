{
  "name": "feitico-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cd apps/web && npx vite",
    "dev:web": "turbo run dev --filter=@feitico/web",
    "dev:api": "turbo run dev --filter=@feitico/api",
    "build": "cd apps/web && npx vite build",
    "build:dev": "cd apps/web && npx vite build --mode development",
    "build:web": "turbo run build --filter=@feitico/web",
    "build:api": "turbo run build --filter=@feitico/api",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "turbo:graph": "turbo run build --graph",
    "deploy:dev": "bash ./deploy.sh dev",
    "deploy:prod": "bash ./deploy.sh prod",
    "prepare": "husky",
    "clean": "turbo run clean --continue"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@11.8.0"
}
