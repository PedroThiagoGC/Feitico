{
  "name": "feitico-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@feitico/web",
    "dev:api": "turbo run dev --filter=@feitico/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "clean": "turbo run clean --continue"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.8.0"
}
