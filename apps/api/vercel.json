{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(?<path>.*)",
      "dest": "dist/main.js?path=$path"
    },
    {
      "src": "/(?<path>.*)",
      "dest": "dist/main.js?path=$path"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
